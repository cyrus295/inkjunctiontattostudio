# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# Render automatically sets this — no need to add it manually on Render
# RENDER_EXTERNAL_URL=https://your-service.onrender.com

# ─── Database (PostgreSQL via Prisma) ────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set to your deployed frontend URL (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# ─── Cloudinary (for file uploads in production) ─────────────────────────────
# Sign up free at https://cloudinary.com → Dashboard → copy these 3 values
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret


# https://inkjunctiontattostudio-1bk1.onrender.com