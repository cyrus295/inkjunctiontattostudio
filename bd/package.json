{
  "name": "ink-junction-tattoos-server",
  "version": "1.0.0",
  "description": "Backend API for Ink Junction Tattoos portfolio",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "build": "prisma generate",
    "start": "node src/index.js",
    "seed": "node src/seed.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^5.19.0",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "prisma": "^5.19.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
